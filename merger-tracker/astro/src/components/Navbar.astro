---
const pathname = Astro.url.pathname;

const navLinks = [
  { path: '/', label: 'Dashboard', shortcut: 'd' },
  { path: '/mergers', label: 'Mergers', shortcut: 'm' },
  { path: '/timeline', label: 'Timeline', shortcut: 't' },
  { path: '/industries', label: 'Industries', shortcut: 'i' },
  { path: '/commentary', label: 'Commentary', shortcut: 'c' },
  { path: '/analysis', label: 'Analysis', shortcut: 'a' },
  { path: '/digest', label: 'Catch me up' },
];

function isActive(path: string) {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
}
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white border-b border-gray-100"
>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-lg"
  >
    Skip to main content
  </a>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex items-center">
        <a href="/" class="flex items-center gap-2.5 group">
          <span class="text-lg font-bold text-primary tracking-tight">
            australian merger tracker
          </span>
        </a>
        <div class="hidden sm:ml-10 sm:flex sm:space-x-1">
          {navLinks.map(({ path, label, shortcut }) => (
            <a
              href={path}
              class={`relative inline-flex items-center px-3 py-2 rounded-lg text-sm font-medium transition-all duration-150 ${
                isActive(path)
                  ? 'bg-primary/10 text-primary'
                  : 'text-gray-500 hover:text-gray-900 hover:bg-gray-100/80'
              }`}
              data-shortcut={shortcut || undefined}
            >
              {label}
            </a>
          ))}
        </div>
      </div>
      <div class="flex items-center gap-1">
        <!-- Notification bell (tracking island) -->
        <div class="relative">
          <button
            id="notification-bell"
            class="relative inline-flex items-center justify-center p-2 rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-100/80 transition-all duration-150"
            aria-expanded="false"
            aria-label="Notifications"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
            </svg>
            <span id="notification-badge" class="hidden absolute top-1 right-1 flex h-4 w-4 items-center justify-center">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-40"></span>
              <span class="relative inline-flex h-3.5 w-3.5 items-center justify-center rounded-full bg-accent text-[10px] font-bold text-white" id="notification-count">0</span>
            </span>
          </button>
          <!-- Notification panel rendered by tracking.js -->
          <div id="notification-panel" class="hidden fixed left-1/2 -translate-x-1/2 top-16 sm:absolute sm:left-auto sm:translate-x-0 sm:right-0 sm:top-full sm:mt-2 w-[calc(100vw-1rem)] sm:w-96 bg-white/95 backdrop-blur-lg rounded-2xl shadow-elevated border border-gray-100 z-50 max-h-[70vh] sm:max-h-[80vh] overflow-hidden flex flex-col" role="dialog" aria-label="Notifications panel">
            <div class="px-5 py-3.5 border-b border-gray-100 bg-gray-50/80 flex-shrink-0">
              <h2 class="text-sm font-semibold text-gray-900">
                Tracked
                <span id="tracked-count-label" class="ml-2 text-gray-400 font-normal"></span>
              </h2>
            </div>
            <div id="notification-content" class="overflow-y-auto flex-1">
              <div class="px-5 py-10 text-center">
                <div class="w-12 h-12 rounded-2xl bg-gray-50 flex items-center justify-center mx-auto mb-3">
                  <svg class="h-6 w-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                  </svg>
                </div>
                <p class="text-sm font-medium text-gray-500 mb-1">No tracked mergers yet</p>
                <p class="text-xs text-gray-400">
                  Visit a merger's page and click "Track" to receive updates
                </p>
              </div>
            </div>
            <div id="notification-footer" class="hidden px-5 py-3 border-t border-gray-100 bg-gray-50/80 flex-shrink-0">
              <div class="flex items-center gap-1.5 text-xs font-medium">
                <a href="/mergers?tracked=true" class="text-primary hover:text-primary-dark transition-colors">View tracked</a>
                <span class="text-gray-400">&middot;</span>
                <a href="/mergers" class="text-primary hover:text-primary-dark transition-colors">View all mergers</a>
              </div>
            </div>
          </div>
        </div>
        <!-- Mobile menu button -->
        <button
          id="mobile-menu-button"
          class="sm:hidden inline-flex items-center justify-center p-2 rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-100/80 transition-all duration-150"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Open main menu"
        >
          <svg id="menu-icon-open" class="block h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg id="menu-icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-gray-100 bg-white/95 backdrop-blur-lg">
    <nav aria-label="Mobile navigation" class="px-3 py-3 space-y-1">
      {navLinks.map(({ path, label }) => (
        <a
          href={path}
          class={`block px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-150 ${
            isActive(path)
              ? 'bg-primary/10 text-primary'
              : 'text-gray-600 hover:bg-gray-100 hover:text-gray-900'
          }`}
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (menuButton && mobileMenu) {
    menuButton.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      iconOpen?.classList.toggle('hidden');
      iconClose?.classList.toggle('hidden');
      menuButton.setAttribute('aria-expanded', String(!isOpen));
      menuButton.setAttribute('aria-label', isOpen ? 'Open main menu' : 'Close main menu');
    });
  }

  // Scroll hide/show navbar
  let lastScrollY = 0;
  const nav = document.getElementById('main-nav');

  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;

    if (nav) {
      if (currentScrollY > 10) {
        nav.classList.add('bg-white/80', 'backdrop-blur-lg', 'shadow-glass', 'border-gray-200/50');
        nav.classList.remove('bg-white', 'border-gray-100');
      } else {
        nav.classList.remove('bg-white/80', 'backdrop-blur-lg', 'shadow-glass', 'border-gray-200/50');
        nav.classList.add('bg-white', 'border-gray-100');
      }

      if (currentScrollY < lastScrollY) {
        nav.classList.remove('-translate-y-full');
      } else if (currentScrollY > lastScrollY && currentScrollY > 50) {
        nav.classList.add('-translate-y-full');
      }
    }

    lastScrollY = currentScrollY;
  }, { passive: true });

  // Shortcut hint badges on "g" key
  let gTimer: ReturnType<typeof setTimeout> | null = null;
  window.addEventListener('keydown', (e) => {
    const target = e.target as HTMLElement;
    if (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.tagName === 'SELECT' || target.isContentEditable) return;
    if (e.key === 'g' && !e.ctrlKey && !e.metaKey && !e.altKey) {
      document.querySelectorAll('[data-shortcut]').forEach(el => {
        const shortcut = el.getAttribute('data-shortcut');
        let badge = el.querySelector('.shortcut-badge');
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'shortcut-badge absolute -top-1 -right-1 flex items-center justify-center w-4 h-4 rounded bg-primary text-[10px] font-bold text-white shadow-sm animate-fade-in';
          badge.textContent = shortcut;
          (el as HTMLElement).style.position = 'relative';
          el.appendChild(badge);
        }
        (badge as HTMLElement).style.display = '';
      });
      if (gTimer) clearTimeout(gTimer);
      gTimer = setTimeout(() => {
        document.querySelectorAll('.shortcut-badge').forEach(el => {
          (el as HTMLElement).style.display = 'none';
        });
      }, 2000);
    }
  });
  window.addEventListener('keyup', (e) => {
    if (e.key !== 'g') {
      document.querySelectorAll('.shortcut-badge').forEach(el => {
        (el as HTMLElement).style.display = 'none';
      });
    }
  });
</script>
