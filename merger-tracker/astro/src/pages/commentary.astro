---
import Base from '../layouts/Base.astro';
import StatusBadge from '../components/StatusBadge.astro';
import WaiverBadge from '../components/WaiverBadge.astro';
import ExternalLinkIcon from '../components/ExternalLinkIcon.astro';
import { getCommentary } from '../data/loader';
import { formatDate } from '../utils/dates';
import { marked } from 'marked';
import { PROSE_MARKDOWN } from '../utils/classNames';

const data = getCommentary();
const items = data?.items || [];
---

<Base
  title="Commentary"
  description="In-depth analysis of Australian merger cases — examining ACCC decisions, competitive concerns, economic reasoning, and M&A policy implications."
  url="/commentary"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 animate-fade-in">
    <div class="mb-4">
      <p class="text-sm text-gray-400">
        {items.length} {items.length === 1 ? 'entry' : 'entries'}
      </p>
    </div>

    <div class="space-y-4">
      {items.map((item) => (
        <div class="bg-white rounded-2xl border border-gray-100 shadow-card overflow-hidden">
          <div class="p-5 border-b border-gray-50">
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <a
                    href={`/mergers/${item.merger_id}`}
                    class="text-base font-semibold text-gray-900 hover:text-primary transition-colors truncate"
                  >
                    {item.merger_name}
                  </a>
                  {item.is_waiver && <WaiverBadge class="flex-shrink-0" />}
                </div>
                <p class="text-xs text-gray-400 mt-1">
                  {item.merger_id} &middot; {item.stage || 'N/A'} &middot; {item.is_waiver ? 'Applied' : 'Notified'}: {formatDate(item.effective_notification_datetime)}
                  {item.determination_publication_date && (
                    <>
                      {' \u00B7 '}
                      {item.determination_url ? (
                        <a
                          href={item.determination_url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1 text-primary hover:text-primary-dark transition-colors"
                        >
                          Determined: {formatDate(item.determination_publication_date)}
                          <ExternalLinkIcon class="h-3 w-3" />
                        </a>
                      ) : (
                        `Determined: ${formatDate(item.determination_publication_date)}`
                      )}
                    </>
                  )}
                </p>
              </div>
              <StatusBadge status={item.status} determination={item.accc_determination} />
            </div>
          </div>

          {item.comments && item.comments.length > 0 && (
            <div class="divide-y divide-blue-100/60">
              {item.comments.map((comment) => (
                <div class="p-5 bg-gradient-to-r from-blue-50/80 to-indigo-50/30">
                  <div class="flex items-start gap-3">
                    <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center">
                      <svg class="h-4 w-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      {comment.commentary && (
                        <div class={PROSE_MARKDOWN} set:html={marked(comment.commentary)} />
                      )}
                      {comment.tags && comment.tags.length > 0 && (
                        <div class="flex flex-wrap gap-1.5 mt-3">
                          {comment.tags.map((tag) => (
                            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-blue-100/80 text-blue-700">
                              {tag}
                            </span>
                          ))}
                        </div>
                      )}
                      <div class="flex items-center gap-3 mt-3">
                        {comment.date && (
                          <p class="text-xs text-gray-400">Updated {formatDate(comment.date)}</p>
                        )}
                        {comment.author && (
                          <p class="text-xs text-gray-400">by {comment.author}</p>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    {items.length === 0 && (
      <div class="text-center py-16">
        <p class="text-gray-500 font-medium">No commentary available yet</p>
      </div>
    )}
  </div>
</Base>
