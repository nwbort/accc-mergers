---
import Base from '../layouts/Base.astro';
import WaiverBadge from '../components/WaiverBadge.astro';
import ExternalLinkIcon from '../components/ExternalLinkIcon.astro';
import { getDigest } from '../data/loader';
import { formatDate } from '../utils/dates';
import { marked } from 'marked';
import { SUBSCRIBE_ENDPOINT, TURNSTILE_SITE_KEY } from '../config';

const digest = getDigest();

function formatDateRange(startDate, endDate) {
  if (!startDate || !endDate) return '';
  const start = new Date(startDate);
  const end = new Date(endDate);
  const startDay = start.getDate();
  const endDay = end.getDate();
  const startMonth = start.toLocaleDateString('en-AU', { month: 'long' });
  const endMonth = end.toLocaleDateString('en-AU', { month: 'long' });
  const year = end.getFullYear();
  if (start.getTime() === end.getTime()) return `${startDay} ${startMonth} ${year}`;
  if (startMonth === endMonth) return `${startDay}-${endDay} ${startMonth} ${year}`;
  return `${startDay} ${startMonth} to ${endDay} ${endMonth} ${year}`;
}

function getFirstParagraph(description) {
  if (!description) return '';
  const paragraphs = description.split('\n\n').map(p => p.trim()).filter(p => p);
  for (const para of paragraphs) {
    const plainText = para.replace(/\*\*/g, '').replace(/\*/g, '').trim();
    if (plainText.split(/\s+/).length > 1) return para;
  }
  return paragraphs[0] || '';
}

function getDeterminationPdf(events) {
  if (!events || events.length === 0) return null;
  const determinationEvent = events
    .filter(e => e.display_title && e.display_title.includes('determination') && e.url_gh)
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())[0];
  return determinationEvent?.url_gh || null;
}

const COLOR_CLASSES = {
  'new-merger': {
    borderLeft: 'border-l-new-merger', borderLight: 'border-new-merger-light/20',
    headerBg: 'from-new-merger-pale/50', emptyText: 'text-new-merger/70',
    text: 'text-new-merger', hoverText: 'hover:text-new-merger-dark',
    cardFrom: 'from-new-merger-pale', cardTo: 'to-new-merger-pale/50',
    cardBorder: 'border-new-merger-light/30', groupHoverText: 'group-hover:text-new-merger-dark',
    labelText: 'text-new-merger-dark/80', hoverBg: 'hover:bg-new-merger-pale/40',
  },
  'cleared': {
    borderLeft: 'border-l-cleared', borderLight: 'border-cleared-light/20',
    headerBg: 'from-cleared-pale/50', emptyText: 'text-cleared/70',
    text: 'text-cleared', hoverText: 'hover:text-cleared-dark',
    cardFrom: 'from-cleared-pale', cardTo: 'to-cleared-pale/50',
    cardBorder: 'border-cleared-light/30', groupHoverText: 'group-hover:text-cleared-dark',
    labelText: 'text-cleared-dark/80', hoverBg: 'hover:bg-cleared-pale/40',
  },
  'declined': {
    borderLeft: 'border-l-declined', borderLight: 'border-declined-light/20',
    headerBg: 'from-declined-pale/50', emptyText: 'text-declined/70',
    text: 'text-declined', hoverText: 'hover:text-declined-dark',
    cardFrom: 'from-declined-pale', cardTo: 'to-declined-pale/50',
    cardBorder: 'border-declined-light/30', groupHoverText: 'group-hover:text-declined-dark',
    labelText: 'text-declined-dark/80', hoverBg: 'hover:bg-declined-pale/40',
  },
  'phase-1': {
    borderLeft: 'border-l-phase-1', borderLight: 'border-phase-1-light/20',
    headerBg: 'from-phase-1-pale/50', emptyText: 'text-phase-1/70',
    text: 'text-phase-1', hoverText: 'hover:text-phase-1-dark',
    cardFrom: 'from-phase-1-pale', cardTo: 'to-phase-1-pale/50',
    cardBorder: 'border-phase-1-light/30', groupHoverText: 'group-hover:text-phase-1-dark',
    labelText: 'text-phase-1-dark/80', hoverBg: 'hover:bg-phase-1-pale/40',
  },
  'phase-2': {
    borderLeft: 'border-l-phase-2', borderLight: 'border-phase-2-light/20',
    headerBg: 'from-phase-2-pale/50', emptyText: 'text-phase-2/70',
    text: 'text-phase-2', hoverText: 'hover:text-phase-2-dark',
    cardFrom: 'from-phase-2-pale', cardTo: 'to-phase-2-pale/50',
    cardBorder: 'border-phase-2-light/30', groupHoverText: 'group-hover:text-phase-2-dark',
    labelText: 'text-phase-2-dark/80', hoverBg: 'hover:bg-phase-2-pale/40',
  },
};

const dateRange = digest ? formatDateRange(digest.period_start, digest.period_end) : '';

const summaryCards = digest ? [
  { id: 'new-mergers', colorKey: 'new-merger', count: digest.new_deals_notified.length, label: 'New deals notified' },
  { id: 'mergers-approved', colorKey: 'cleared', count: digest.deals_cleared.length, label: 'Deals cleared' },
  { id: 'mergers-declined', colorKey: 'declined', count: digest.deals_declined.length, label: 'Deals declined' },
  { id: 'ongoing-phase-1', colorKey: 'phase-1', count: digest.ongoing_phase_1.length, label: 'Ongoing phase 1' },
  { id: 'ongoing-phase-2', colorKey: 'phase-2', count: digest.ongoing_phase_2.length, label: 'Ongoing phase 2' },
] : [];
---

<Base
  title="Catch me up - ACCC Merger Tracker"
  description="Weekly roundup of Australian merger activity: new ACCC notifications, Phase 1 clearances, Phase 2 launches, and upcoming consultation deadlines — all in one digest."
  url="/digest"
>
  {digest && (
    <div class="min-h-screen bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Header -->
        <div class="mb-6">
          <h1 class="text-3xl font-bold text-gray-900 mb-2">Catch me up</h1>
          <p class="text-gray-600">Weekly digest of merger activity from {dateRange}</p>
        </div>

        <!-- Email signup -->
        <div id="digest-signup" class="mb-6 rounded-xl border border-gray-200 bg-white px-5 py-4 shadow-card">
          <form id="digest-form" class="flex flex-col gap-3">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:gap-4">
              <div class="flex-1">
                <label for="digest-email" class="mb-1 block text-sm font-medium text-gray-700">
                  Get this delivered every Monday morning
                </label>
                <input
                  id="digest-email"
                  type="email"
                  autocomplete="email"
                  required
                  placeholder="you@example.com"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary disabled:opacity-50"
                />
              </div>
              <button
                type="submit"
                id="digest-submit"
                disabled
                class="shrink-0 rounded-lg bg-primary px-5 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary-dark disabled:opacity-50"
              >
                Subscribe
              </button>
            </div>
            <div id="turnstile-container"></div>
          </form>
          <p id="digest-error" class="hidden mt-2 text-xs text-red-600"></p>
        </div>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
          {summaryCards.map(({ id, colorKey, count, label }) => {
            const c = COLOR_CLASSES[colorKey];
            return (
              <a
                href={`#${id}`}
                class={`bg-gradient-to-br ${c.cardFrom} ${c.cardTo} rounded-lg shadow-card border ${c.cardBorder} p-4 hover:shadow-card-hover hover:scale-105 transition-all cursor-pointer text-left group block`}
              >
                <div class={`text-2xl font-bold ${c.text} ${c.groupHoverText} transition-colors`}>{count}</div>
                <div class={`text-sm ${c.labelText} font-medium`}>{label}</div>
              </a>
            );
          })}
        </div>

        <!-- Tables -->
        <div class="space-y-6">
          {/* New mergers */}
          {(() => { const c = COLOR_CLASSES['new-merger']; return (
            <div id="new-mergers" class={`bg-white rounded-2xl border-l-4 ${c.borderLeft} border-t border-r border-b border-gray-100 shadow-card overflow-hidden`}>
              <div class={`px-5 sm:px-6 py-4 border-b ${c.borderLight} bg-gradient-to-r ${c.headerBg} to-transparent`}>
                <div class="flex items-center justify-between">
                  <h2 class="text-lg font-semibold text-gray-900">New mergers</h2>
                </div>
              </div>
              {digest.new_deals_notified.length === 0 ? (
                <div class="px-5 sm:px-6 py-4"><p class={`${c.emptyText} text-sm`}>No new mergers this week</p></div>
              ) : (
                <div class="overflow-x-auto">
                  <table class="min-w-full divide-y divide-gray-100">
                    <thead><tr class="bg-gray-50/80">
                      <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Merger</th>
                      <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Notification date</th>
                      <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Summary</th>
                    </tr></thead>
                    <tbody class="divide-y divide-gray-50">
                      {digest.new_deals_notified.map((merger) => (
                        <tr class={`relative ${c.hoverBg} transition-colors`}>
                          <td class="px-5 sm:px-6 py-4 text-sm text-gray-900">
                            <div class="flex items-start gap-2">
                              <a href={`/mergers/${merger.merger_id}`} class={`${c.text} ${c.hoverText} font-medium transition-colors after:absolute after:inset-0`}>{merger.merger_name}</a>
                              {merger.is_waiver && <WaiverBadge class="relative z-10" />}
                            </div>
                            <div class="text-xs text-gray-400 mt-0.5"><span>{merger.merger_id}</span></div>
                          </td>
                          <td class="px-5 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                            {merger.effective_notification_datetime ? formatDate(merger.effective_notification_datetime) : 'N/A'}
                          </td>
                          <td class="px-5 sm:px-6 py-4 text-sm text-gray-600">
                            <div class="prose prose-sm max-w-none" set:html={marked(getFirstParagraph(merger.merger_description))} />
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          );})()}

          {/* Mergers approved */}
          {(() => { const c = COLOR_CLASSES['cleared']; return (
            <div id="mergers-approved" class={`bg-white rounded-2xl border-l-4 ${c.borderLeft} border-t border-r border-b border-gray-100 shadow-card overflow-hidden`}>
              <div class={`px-5 sm:px-6 py-4 border-b ${c.borderLight} bg-gradient-to-r ${c.headerBg} to-transparent`}>
                <h2 class="text-lg font-semibold text-gray-900">Mergers approved</h2>
              </div>
              {digest.deals_cleared.length === 0 ? (
                <div class="px-5 sm:px-6 py-4"><p class={`${c.emptyText} text-sm`}>No mergers approved this week</p></div>
              ) : (
                <div class="overflow-x-auto">
                  <table class="min-w-full divide-y divide-gray-100">
                    <thead><tr class="bg-gray-50/80">
                      <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Merger</th>
                      <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Determination date</th>
                      <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Determination</th>
                    </tr></thead>
                    <tbody class="divide-y divide-gray-50">
                      {digest.deals_cleared.map((merger) => {
                        const pdfUrl = getDeterminationPdf(merger.events);
                        const determination = merger.accc_determination || merger.phase_1_determination || merger.phase_2_determination || 'Approved';
                        return (
                          <tr class={`relative ${c.hoverBg} transition-colors`}>
                            <td class="px-5 sm:px-6 py-4 text-sm text-gray-900">
                              <div class="flex items-start gap-2">
                                <a href={`/mergers/${merger.merger_id}`} class={`${c.text} ${c.hoverText} font-medium transition-colors after:absolute after:inset-0`}>{merger.merger_name}</a>
                                {merger.is_waiver && <WaiverBadge class="relative z-10" />}
                              </div>
                              <div class="text-xs text-gray-400 mt-0.5">{merger.merger_id}</div>
                            </td>
                            <td class="px-5 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                              {merger.determination_publication_date ? formatDate(merger.determination_publication_date) : 'N/A'}
                            </td>
                            <td class="px-5 sm:px-6 py-4 whitespace-nowrap text-sm">
                              {pdfUrl ? (
                                <a href={pdfUrl} target="_blank" rel="noopener noreferrer" class={`${c.text} ${c.hoverText} font-medium transition-colors relative z-10 inline-flex items-center gap-1`}>
                                  {determination}<ExternalLinkIcon class="h-3.5 w-3.5" />
                                </a>
                              ) : <span class="text-gray-600">{determination}</span>}
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          );})()}

          {/* Mergers declined */}
          {(() => { const c = COLOR_CLASSES['declined']; return (
            <div id="mergers-declined" class={`bg-white rounded-2xl border-l-4 ${c.borderLeft} border-t border-r border-b border-gray-100 shadow-card overflow-hidden`}>
              <div class={`px-5 sm:px-6 py-4 border-b ${c.borderLight} bg-gradient-to-r ${c.headerBg} to-transparent`}>
                <h2 class="text-lg font-semibold text-gray-900">Mergers declined</h2>
              </div>
              {digest.deals_declined.length === 0 ? (
                <div class="px-5 sm:px-6 py-4"><p class={`${c.emptyText} text-sm`}>No mergers declined this week</p></div>
              ) : (
                <div class="overflow-x-auto">
                  <table class="min-w-full divide-y divide-gray-100">
                    <thead><tr class="bg-gray-50/80">
                      <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Merger</th>
                      <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Determination date</th>
                      <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Determination</th>
                    </tr></thead>
                    <tbody class="divide-y divide-gray-50">
                      {digest.deals_declined.map((merger) => {
                        const pdfUrl = getDeterminationPdf(merger.events);
                        const determination = merger.accc_determination || 'Not approved';
                        return (
                          <tr class={`relative ${c.hoverBg} transition-colors`}>
                            <td class="px-5 sm:px-6 py-4 text-sm text-gray-900">
                              <div class="flex items-start gap-2">
                                <a href={`/mergers/${merger.merger_id}`} class={`${c.text} ${c.hoverText} font-medium transition-colors after:absolute after:inset-0`}>{merger.merger_name}</a>
                                {merger.is_waiver && <WaiverBadge class="relative z-10" />}
                              </div>
                              <div class="text-xs text-gray-400 mt-0.5">{merger.merger_id}</div>
                            </td>
                            <td class="px-5 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                              {merger.determination_publication_date ? formatDate(merger.determination_publication_date) : 'N/A'}
                            </td>
                            <td class="px-5 sm:px-6 py-4 whitespace-nowrap text-sm">
                              {pdfUrl ? (
                                <a href={pdfUrl} target="_blank" rel="noopener noreferrer" class={`${c.text} ${c.hoverText} font-medium transition-colors relative z-10 inline-flex items-center gap-1`}>
                                  {determination}<ExternalLinkIcon class="h-3.5 w-3.5" />
                                </a>
                              ) : <span class="text-gray-600">{determination}</span>}
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          );})()}

          {/* Ongoing phase 1 & phase 2 - similar pattern */}
          {[
            { id: 'ongoing-phase-1', title: 'Ongoing - phase 1 - initial assessment', empty: 'No ongoing phase 1 mergers', colorKey: 'phase-1', mergers: digest.ongoing_phase_1 },
            { id: 'ongoing-phase-2', title: 'Ongoing - phase 2 - detailed assessment', empty: 'No ongoing phase 2 mergers', colorKey: 'phase-2', mergers: digest.ongoing_phase_2 },
          ].map(({ id, title, empty, colorKey, mergers }) => {
            const c = COLOR_CLASSES[colorKey];
            return (
              <div id={id} class={`bg-white rounded-2xl border-l-4 ${c.borderLeft} border-t border-r border-b border-gray-100 shadow-card overflow-hidden`}>
                <div class={`px-5 sm:px-6 py-4 border-b ${c.borderLight} bg-gradient-to-r ${c.headerBg} to-transparent`}>
                  <h2 class="text-lg font-semibold text-gray-900">{title}</h2>
                </div>
                {mergers.length === 0 ? (
                  <div class="px-5 sm:px-6 py-4"><p class={`${c.emptyText} text-sm`}>{empty}</p></div>
                ) : (
                  <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-100">
                      <thead><tr class="bg-gray-50/80">
                        <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Merger</th>
                        <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Notification date</th>
                        <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Determination due date</th>
                        <th class="px-5 sm:px-6 py-3.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Summary</th>
                      </tr></thead>
                      <tbody class="divide-y divide-gray-50">
                        {mergers.map((merger) => (
                          <tr class={`relative ${c.hoverBg} transition-colors`}>
                            <td class="px-5 sm:px-6 py-4 text-sm text-gray-900">
                              <div class="flex items-start gap-2">
                                <a href={`/mergers/${merger.merger_id}`} class={`${c.text} ${c.hoverText} font-medium transition-colors after:absolute after:inset-0`}>{merger.merger_name}</a>
                                {merger.is_waiver && <WaiverBadge class="relative z-10" />}
                              </div>
                              <div class="text-xs text-gray-400 mt-0.5">{merger.merger_id}</div>
                            </td>
                            <td class="px-5 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                              {merger.effective_notification_datetime ? formatDate(merger.effective_notification_datetime) : 'N/A'}
                            </td>
                            <td class="px-5 sm:px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                              {merger.end_of_determination_period ? formatDate(merger.end_of_determination_period) : 'N/A'}
                            </td>
                            <td class="px-5 sm:px-6 py-4 text-sm text-gray-600">
                              <div class="prose prose-sm max-w-none" set:html={marked(getFirstParagraph(merger.merger_description))} />
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}
</Base>

<script define:vars={{ SUBSCRIBE_ENDPOINT, TURNSTILE_SITE_KEY }}>
  // Digest email signup with Turnstile
  const form = document.getElementById('digest-form');
  const emailInput = document.getElementById('digest-email');
  const submitBtn = document.getElementById('digest-submit');
  const signupDiv = document.getElementById('digest-signup');
  const errorEl = document.getElementById('digest-error');
  const turnstileContainer = document.getElementById('turnstile-container');
  let turnstileToken = '';
  let widgetId = null;

  function updateSubmitState() {
    if (submitBtn) {
      submitBtn.disabled = !emailInput?.value.trim() || !turnstileToken;
    }
  }

  emailInput?.addEventListener('input', updateSubmitState);

  // Load Turnstile
  const script = document.createElement('script');
  script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
  script.async = true;
  script.onload = () => {
    if (turnstileContainer && window.turnstile) {
      widgetId = window.turnstile.render(turnstileContainer, {
        sitekey: TURNSTILE_SITE_KEY,
        callback: (token) => { turnstileToken = token; updateSubmitState(); },
        'expired-callback': () => { turnstileToken = ''; updateSubmitState(); },
        'error-callback': () => { turnstileToken = ''; updateSubmitState(); },
      });
    }
  };
  document.head.appendChild(script);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput?.value.trim();
    if (!email || !turnstileToken) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Subscribing\u2026';
    errorEl?.classList.add('hidden');

    try {
      const resp = await fetch(SUBSCRIBE_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, 'cf-turnstile-response': turnstileToken }),
      });
      const data = await resp.json();
      if (!resp.ok) {
        errorEl.textContent = data.error || 'Something went wrong. Please try again.';
        errorEl?.classList.remove('hidden');
        submitBtn.textContent = 'Subscribe';
        turnstileToken = '';
        if (widgetId !== null && window.turnstile) window.turnstile.reset(widgetId);
        updateSubmitState();
      } else {
        signupDiv.innerHTML = `<div class="flex items-center gap-3 rounded-xl border border-primary/20 bg-primary/5 px-5 py-4">
          <svg class="h-5 w-5 shrink-0 text-primary" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
          </svg>
          <p class="text-sm font-medium text-primary">Subscribed! You\u2019ll get the digest every Monday morning.</p>
        </div>`;
      }
    } catch {
      errorEl.textContent = 'Could not connect. Please try again.';
      errorEl?.classList.remove('hidden');
      submitBtn.textContent = 'Subscribe';
      turnstileToken = '';
      if (widgetId !== null && window.turnstile) window.turnstile.reset(widgetId);
      updateSubmitState();
    }
  });
</script>
