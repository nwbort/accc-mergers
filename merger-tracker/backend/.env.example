# Backend Configuration
PORT=8000
HOST=0.0.0.0

# CORS Configuration (comma-separated list of allowed origins)
# For local development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# For production (Railway), set to your frontend domain:
# ALLOWED_ORIGINS=https://mergers.fyi,https://www.mergers.fyi
#
# Note: Cloudflare Pages preview branches (*.mergers-fyi.pages.dev) are
# automatically allowed via regex pattern in main.py

# Database
DATABASE_PATH=mergers.db

# ============================================================
# Email Notification System Configuration
# ============================================================

# Resend API Key (required for sending emails)
# Get your API key from: https://resend.com/api-keys
# Example: re_123abc456def789...
RESEND_API_KEY=

# Email sender address (must be verified in Resend)
# Format: "Display Name <email@domain.com>"
FROM_EMAIL=ACCC Mergers <notifications@mergers.fyi>

# Base URL for email links (verification, unsubscribe)
# Used in verification and unsubscribe links in emails
BASE_URL=https://mergers.fyi

# Daily Digest Scheduler Configuration

# Enable/disable the automatic daily digest scheduler
# Set to "true" to enable automatic daily emails
# Set to "false" to disable (you can still manually trigger via API)
# Default: false (disabled)
ENABLE_DIGEST_SCHEDULER=false

# Time to send daily digest (UTC timezone)
# Hour: 0-23 (default: 9 = 9 AM UTC / 7 PM AEST / 8 PM AEDT)
# Minute: 0-59 (default: 0)
DIGEST_HOUR=9
DIGEST_MINUTE=0
